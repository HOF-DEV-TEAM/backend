<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verification Failed — Heritage of Faith Church</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #040654 0%, #0a1172 50%, #1a237e 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .card {
      background: #ffffff;
      border-radius: 20px;
      padding: 56px 48px;
      max-width: 480px;
      width: 100%;
      text-align: center;
      box-shadow: 0 25px 60px rgba(0,0,0,0.3);
    }
    .logo {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      object-fit: cover;
      margin-bottom: 28px;
      border: 3px solid #e8eaf6;
    }
    .icon-circle {
      width: 72px;
      height: 72px;
      background: linear-gradient(135deg, #ef5350, #e53935);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 28px;
    }
    .icon-circle svg { width: 36px; height: 36px; fill: none; stroke: #fff; stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; }
    h1 { font-size: 26px; font-weight: 700; color: #040654; margin-bottom: 14px; line-height: 1.3; }
    p { font-size: 16px; color: #64748b; line-height: 1.7; margin-bottom: 16px; }
    .hint {
      font-size: 14px;
      color: #94a3b8;
      background: #f8fafc;
      border-radius: 8px;
      padding: 14px 20px;
      margin-bottom: 36px;
      line-height: 1.6;
    }
    .church-name {
      font-size: 12px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #94a3b8;
      margin-top: 32px;
      padding-top: 24px;
      border-top: 1px solid #f1f5f9;
      margin-bottom: 0;
    }
  </style>
</head>
<body>
  <div class="card">
    <img src="https://s3.eu-west-2.amazonaws.com/hof--s3/hof/HoF_Logo_White.png"
         alt="Heritage of Faith Church"
         class="logo"
         onerror="this.style.display='none'">

    <div class="icon-circle">
      <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </div>

    <h1>Link Invalid or Expired</h1>
    <p>This verification link is no longer valid.</p>

    <div class="hint">
      Verification links expire after <strong>24 hours</strong>.
      Please open the app and request a new verification email.
    </div>

    <p class="church-name">Heritage of Faith Church</p>
  </div>
</body>
</html>
