<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Verification Failed — Heritage of Faith Church</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/css/bootstrap.min.css"
          integrity="sha384-B0vP5xmATw1+K9KRQjQERJvTumQW0nPEzvF6L/Z6nronJ3oUOFUFpCjEUQouq2+l"
          crossorigin="anonymous">
</head>
<body style="overflow-x: hidden; background:#F1F1F1; width:100%">

<table border="0" cellpadding="0" cellspacing="0" height="100%" width="100%" id="bodyTable">
    <tr>
        <td align="center" valign="top">
            <table border="0" cellpadding="0" cellspacing="0" width="95%" id="emailContainer">
                <tr>
                    <td align="center" valign="top">
                        <table border="0" cellpadding="" cellspacing="0" width="100%" id="emailHeader"
                               style="background-color:#040654;">
                            <tr>
                                <td align="center" valign="top">
                                    <img src="https://s3.eu-west-2.amazonaws.com/hof--s3/hof/HoF_Logo_White.png"
                                         alt="hof_logo" style="max-width:120px;">
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
                <tr>
                    <td align="center" valign="top">
                        <table border="0" cellpadding="0" id="emailBody"
                               style="background-color:white; width: 95%; margin: 15px 0; padding: 40px 25px">
                            <tr style="width: 95%;">
                                <td align="center" valign="top">
                                    <h3 style="width:100%; color:red; direction:ltr; font-family:'Lora', Georgia, serif;
                                               font-size:2rem; font-weight:normal; letter-spacing:1px; line-height:120%;
                                               text-align:center; margin-top:0; margin-bottom:0; padding: 50px 0 20px 0;">
                                        Invalid or Expired Link
                                    </h3>
                                    <p style="font-size:15px; color:#444; text-align:center; padding-bottom:30px;">
                                        This verification link is invalid or has expired.<br>
                                        Please request a new verification email and try again.
                                    </p>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
    <tr>
        <td align="center" valign="top">
            <table border="0" cellpadding="0" cellspacing="0" width="100%" id="emailFooter">
                <tr>
                    <td align="center" valign="top">
                        <!-- footer -->
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>
