{{template "base" .}}

{{define "preheader"}}Your Heritage of Faith Church password reset OTP — valid for {{.DataMap.ExpiresIn}} minutes.{{end}}

{{define "content"}}
  {{/* Heading */}}
  <h1 style="margin:0 0 8px; font-size:26px; font-weight:700; font-family:Georgia,serif;
              color:#040654; line-height:1.3;">
    Reset your password
  </h1>
  <p style="margin:0 0 28px; font-size:15px; font-family:Arial,sans-serif;
             color:#64748b; line-height:1.6;">
    Use the one-time code below to complete your reset.
  </p>

  {{/* Greeting */}}
  <p style="margin:0 0 16px; font-size:16px; font-family:Arial,sans-serif;
             color:#1e293b; line-height:1.6;">
    Hi <strong>{{.DataMap.User}}</strong>,
  </p>
  <p style="margin:0 0 32px; font-size:16px; font-family:Arial,sans-serif;
             color:#475569; line-height:1.7;">
    We received a request to reset your password. Enter the OTP below
    in the app to continue. Do not share this code with anyone.
  </p>

  {{/* OTP box */}}
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
    <tr>
      <td align="center" style="padding:0 0 12px;">
        <p style="margin:0 0 10px; font-size:11px; font-family:Arial,sans-serif;
                   color:#94a3b8; letter-spacing:3px; text-transform:uppercase;">
          Your one-time code
        </p>
        <table role="presentation" cellspacing="0" cellpadding="0" border="0">
          <tr>
            <td align="center"
                style="background-color:#f0f4ff; border:2px dashed #040654;
                        border-radius:10px; padding:20px 52px;">
              <p style="margin:0; font-size:40px; font-weight:700; font-family:'Courier New',monospace;
                         color:#040654; letter-spacing:10px; line-height:1;">
                {{.DataMap.OTP}}
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  {{/* Expiry note */}}
  <p style="margin:0 0 32px; font-size:13px; font-family:Arial,sans-serif;
             color:#94a3b8; text-align:center; line-height:1.6;">
    Expires in <strong style="color:#64748b;">{{.DataMap.ExpiresIn}} minutes</strong>
  </p>

  {{/* Divider */}}
  <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
    <tr><td style="border-top:1px solid #e2e8f0; padding-top:24px;">
      <p style="margin:0; font-size:13px; font-family:Arial,sans-serif; color:#94a3b8; line-height:1.6;">
        If you did not request a password reset, please ignore this email —
        your account remains secure.
      </p>
    </td></tr>
  </table>
{{end}}
