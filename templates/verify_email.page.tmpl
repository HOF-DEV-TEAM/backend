{{template "base" .}}

{{define "preheader"}}Verify your email address to activate your Heritage of Faith Church account.{{end}}

{{define "content"}}
  {{/* Heading */}}
  <h1 style="margin:0 0 8px; font-size:26px; font-weight:700; font-family:Georgia,serif;
              color:#040654; line-height:1.3;">
    Verify your email
  </h1>
  <p style="margin:0 0 28px; font-size:15px; font-family:Arial,sans-serif;
             color:#64748b; line-height:1.6;">
    One quick step to activate your account.
  </p>

  {{/* Greeting */}}
  <p style="margin:0 0 16px; font-size:16px; font-family:Arial,sans-serif;
             color:#1e293b; line-height:1.6;">
    Hi <strong>{{.DataMap.User}}</strong>,
  </p>
  <p style="margin:0 0 32px; font-size:16px; font-family:Arial,sans-serif;
             color:#475569; line-height:1.7;">
    Thanks for joining Heritage of Faith Church! Please verify your email
    address so we can activate your account and keep you connected.
  </p>

  {{/* CTA button — table-based for Outlook compatibility */}}
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
    <tr>
      <td align="center" style="padding:0 0 36px;">
        <table role="presentation" cellspacing="0" cellpadding="0" border="0">
          <tr>
            <td align="center" bgcolor="#040654" style="border-radius:8px;">
              <a href="{{.DataMap.VerificationLink}}"
                 target="_blank"
                 style="display:inline-block; color:#ffffff; font-size:15px; font-weight:600;
                         font-family:Arial,sans-serif; text-decoration:none;
                         padding:15px 44px; border-radius:8px; letter-spacing:0.3px;">
                Verify Email Address
              </a>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  {{/* Fallback link */}}
  <p style="margin:0 0 8px; font-size:13px; font-family:Arial,sans-serif; color:#94a3b8;">
    Button not working? Copy and paste this link into your browser:
  </p>
  <p style="margin:0 0 32px; font-size:12px; font-family:Arial,sans-serif;
             color:#64748b; word-break:break-all; line-height:1.6;">
    {{.DataMap.VerificationLink}}
  </p>

  {{/* Divider */}}
  <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%">
    <tr><td style="border-top:1px solid #e2e8f0; padding-top:24px;">
      <p style="margin:0; font-size:13px; font-family:Arial,sans-serif; color:#94a3b8; line-height:1.6;">
        This link expires in <strong style="color:#64748b;">{{.DataMap.ExpiresIn}}</strong>.
        If you did not create an account, you can safely ignore this email.
      </p>
    </td></tr>
  </table>
{{end}}
