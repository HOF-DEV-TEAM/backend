# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=dev
PORT=8080
SERVER_URL=http://localhost:8080

# ── Database ──────────────────────────────────────────────────────────────────
# Option A — full DSN (overrides individual fields below when set)
DATABASE_URL=postgres://hofuser:hofpassword@localhost:5432/hofdb?sslmode=disable

# Option B — individual fields (used when DATABASE_URL is blank)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hofdb
DB_USERNAME=hofuser
DB_PASSWORD=hofpassword
DB_SSL_MODE=disable

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SIGNING_KEY=change-me-to-a-long-random-secret
JWT_SECRET=change-me-to-a-long-random-secret

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ENDPOINT=your-access-key-id
AWS_SECRET=your-secret-access-key
AWS_BUCKET=hof-s3
AWS_BUCKET_PATH=hof/
AWS_BASE_URL=https://s3.amazonaws.com/

# ── Paystack ──────────────────────────────────────────────────────────────────
PAYSTACK_ADDR=https://api.paystack.co
PAYSTACK_SECRET=sk_test_your_paystack_secret_key

# ── Mailer (SendinBlue / Brevo SMTP) ─────────────────────────────────────────
MAILER_EMAIL=no-reply@hofng.org
MAILER_HOST=smtp-relay.brevo.com
MAILER_USERNAME=your-brevo-smtp-login
MAILER_PASSWORD=your-brevo-smtp-api-key
MAILER_PORT=587
MAIL_HEADER=Heritage of Faith Church
TEMPLATE_PATH=./templates/
MAIL_LOGO_URL=https://s3.eu-west-2.amazonaws.com/hof--s3/hof/HoF_Logo_White.png
