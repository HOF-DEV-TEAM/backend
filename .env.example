# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=dev
PORT=8080
SERVER_URL=http://localhost:8080

# ── Database ──────────────────────────────────────────────────────────────────
# Option A — full DSN (overrides individual fields below when set)
DATABASE_URL=postgres://hofuser:hofpassword@localhost:5432/hofdb?sslmode=disable

# Option B — individual fields (used when DATABASE_URL is blank)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hofdb
DB_USERNAME=hofuser
DB_PASSWORD=hofpassword
DB_SSL_MODE=disable

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SIGNING_KEY=change-me-to-a-long-random-secret
JWT_SECRET=change-me-to-a-long-random-secret

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ENDPOINT=your-access-key-id
AWS_SECRET=your-secret-access-key
AWS_BUCKET=hof-s3
AWS_BUCKET_PATH=hof/
AWS_BASE_URL=https://s3.amazonaws.com/

# ── AWS S3 Upload Optimization ────────────────────────────────────────────────
# Multipart upload: chunk size (10MB default, increase for faster uploads on fast networks)
AWS_UPLOAD_PART_SIZE=10485760

# Maximum allowed file size (500MB default, increase if needed)
AWS_MAX_FILE_SIZE=524288000

# Presigned URL expiry time in seconds (3600 = 1 hour)
AWS_PRESIGNED_TTL=3600

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=cloud-name
CLOUDINARY_API_KEY=api-key
CLOUDINARY_API_SECRET=api-secret
CLOUDINARY_UPLOAD_PRESET=upload-preset

# ── Paystack ──────────────────────────────────────────────────────────────────
PAYSTACK_ADDR=https://api.paystack.co
PAYSTACK_SECRET=sk_test_your_paystack_secret_key

# ── Mailer (Brevo SMTP) ───────────────────────────────────────────
MAILER_HOST=smtp-relay.brevo.com
MAILER_USERNAME=your-brevo-smtp-login
MAILER_PASSWORD=your-brevo-smtp-api-key
MAILER_PORT=587
MAILER_EMAIL=test
MAIL_HEADER=Heritage of Faith Church
TEMPLATE_PATH=./templates/
MAIL_LOGO_URL=logo